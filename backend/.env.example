# Все ключи можно ввести прямо в приложении («Подключения» в шапке) —
# значения здесь работают лишь как значения по умолчанию.

# OANDA (демо-токен: https://www.oanda.com/demo-account/tpa/personal_token)
# Пусто — симулированные данные.
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# Anthropic — ИИ-агенты (новостные дебаты + прогнозный уклон).
# Пусто — нейтральные векторы, работают только формулы.
ANTHROPIC_API_KEY=

# Telegram-бот для уведомлений (chat_id задаётся в приложении)
TELEGRAM_BOT_TOKEN=

# Файл базы SQLite
DATABASE_URL=sqlite:///./forex.db
