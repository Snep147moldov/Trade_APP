# Copiază în .env lângă docker-compose.yml și completează.
# Toate sunt opționale: cheile se pot introduce și din UI («Подключения»).

# Domeniul aplicației (fără https://). Lasă gol / șterge linia ca să rulezi
# doar pe IP-ul VPS-ului, pe portul 80, fără certificat.
DOMAIN=trade.exemplu.ro

# Chei API (fallback pentru cele introduse în UI)
TWELVEDATA_API_KEY=
EODHD_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
