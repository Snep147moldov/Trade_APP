# Copiază în .env lângă docker-compose.yml și completează.
# Cheile pot fi introduse și din UI («Подключения») — env-ul e fallback,
# util mai ales la prima pornire pe un server nou (baza de date e goală).

# ── Obligatoriu pentru HTTPS ─────────────────────────────────────────────
# Domeniul aplicației (fără https://). Lasă gol ca să rulezi doar pe
# IP-ul VPS-ului, pe portul 80, fără certificat.
DOMAIN=

# ── Date de piață ────────────────────────────────────────────────────────
# Twelve Data — intraday (5m–4h) + WebSocket. Sursa principală.
TWELVEDATA_API_KEY=
# Request-uri/minut permise de planul TD: 7 pentru free (limita reală e 8),
# 55 pentru Grow, etc.
TWELVEDATA_RPM=7
# EODHD — candele zilnice (inclusiv indici) + cotații batch. Sursă secundară.
EODHD_API_KEY=

# ── ИИ (agenți de știri, chat-asistent, memorie, jurnal) ────────────────
ANTHROPIC_API_KEY=

# ── Notificări (opțional) ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── OANDA (legacy, opțional — doar dacă mai vrei fallback-ul) ───────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice
